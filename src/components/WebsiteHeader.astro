<header
    id="website-header"
    class="px-12 py-4 border-b border-secondary-500 w-full fixed backdrop-blur-md font-medium shadow-lg sticky top-0 z-45 bg-inherit/50"
>
    <div class="h-full max-w-[90%] mx-auto flex items-center justify-between">
        <h1 class="font-black text-xl lg:text-3xl flex items-center justify-start">
            <a
                class=" py-2"
                href="#"
            >
                TypeCrafters HQ
            </>
        </h1>

        <!-- Mobile Menu Button -->
        <div class="md:hidden">
            <button id="sidebar-icon" aria-label="Open navigation menu">
                <svg
                    class="w-8 h-8"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M4 6h16M4 12h16M4 18h16"
                    ></path>
                </svg>
            </button>
        </div>

        <!-- Desktop Navigation -->
        <ul class="hidden md:flex items-center gap-6 lg:gap-5 px-1 py-2 text-sm lg:text-lg">
            <li>
                <a class="hover:text-primary-400 p-2" href="#about-us">About</a>
            </li>
            <li>
                <a class="hover:text-primary-400 p-2" href="#current-projects">Projects</a>
            </li>
            <li>
                <a class="hover:text-primary-400 p-2" href="#blog">Blog</a>
            </li>
            <li>
                <a class="hover:text-primary-400 p-2" href="#contact-us">Contact</a>
            </li>
        </ul>
    </div>
</header>

<!-- Mobile Sidebar -->
<div
    id="sidebar"
    role="navigation"
    class="fixed top-0 right-0 w-[55%] h-full backdrop-blur-md bg-gray-800 from-bg-inherit border-l border-l-slate-800 transform translate-x-full transition-transform duration-300 ease-in-out z-50 md:hidden"
>
    <div class="py-6">
        <button
            id="close-sidebar"
            aria-label="Close navigation menu"
            class="mb-8 pl-6"
        >
            <svg
                class="w-8 h-8"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M6 18L18 6M6 6l12 12"
                ></path>
            </svg>
        </button>

        <!-- Mobile Navigation Links -->
        <ul class="flex flex-col gap-3 font-medium">
            <li>
                <a
                    class="sidebar-link hover:bg-white/10 focus:bg-white/15 py-2 pl-8 block w-full"
                    href="#about-us"
                >
                    About
                </a>
            </li>
            <li>
                <a
                    class="sidebar-link hover:bg-white/10 focus:bg-white/15 py-2 pl-8 block w-full"
                    href="#current-projects"
                >
                    Projects
                </a>
            </li>
            <li>
                <a
                    class="sidebar-link hover:bg-white/10 focus:bg-white/15 py-2 pl-8 block w-full"
                    href="#blog"
                >
                    Blog
                </a>
            </li>
            <li>
                <a
                    class="sidebar-link hover:bg-white/10 focus:bg-white/15 py-2 pl-8 block w-full"
                    href="#contact-us"
                >
                    Contact
                </a>
            </li>
        </ul>
    </div>
</div>

<script>
    const sidebarIcon = document.getElementById("sidebar-icon");
    const sidebar = document.getElementById("sidebar");
    const closeSidebar = document.getElementById("close-sidebar");

    // Abrir sidebar
    sidebarIcon?.addEventListener("click", () => {
        sidebar?.classList.remove("translate-x-full");
    });

    // Cerrar sidebar
    closeSidebar?.addEventListener("click", () => {
        sidebar?.classList.add("translate-x-full");
    });

    // Cerrar al hacer click en los enlaces
    const sidebarLinks = document.querySelectorAll(".sidebar-link");
    sidebarLinks?.forEach((link) => {
        link.addEventListener("click", () => {
            sidebar?.classList.add("translate-x-full");
        });
    });

    // Cerrar al hacer click fuera del sidebar
    document.addEventListener("click", (e) => {
        const target = e.target as HTMLElement;
        if (!sidebar?.contains(target) && !sidebarIcon?.contains(target)) {
            sidebar?.classList.add("translate-x-full");
        }
    });
</script>